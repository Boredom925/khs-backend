# ─── MongoDB Atlas ──────────────────────────────
# Get this from: https://cloud.mongodb.com → Your Cluster → Connect → Drivers
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/kolkata_high_school?retryWrites=true&w=majority

# ─── Server ──────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── Email (for contact form — use Gmail App Password) ───
# Enable 2FA on Gmail → Google Account → Security → App Passwords → Generate
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_16_char_app_password
EMAIL_RECIPIENT=principal@kolkatahighschool.edu.in

# ─── Frontend URL (for CORS) ─────────────────────
# During dev: http://localhost:3000 or use your live site
CLIENT_URL=http://localhost:5500
